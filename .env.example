# OAYA Flutter — Environment Variables
# Copy this file to assets/.env and fill in your values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Stripe (test mode)
STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Mailtrap (for order confirmation emails via Edge Function)
MAILTRAP_API_TOKEN=your-mailtrap-token
MAILTRAP_SENDER_EMAIL=noreply@oaya.store
